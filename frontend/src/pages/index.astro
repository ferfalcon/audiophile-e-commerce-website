---
import SiteFooter from '../components/SiteFooter.astro';
import Welcome from '../components/Welcome.astro';
import { siteFooterContent } from '../data/footer';
import Layout from '../layouts/Layout.astro';

const homeFooterContent = {
	...siteFooterContent,
	navigation: siteFooterContent.navigation.map((item) => ({
		...item,
		current: item.href === '/',
	})),
};
---

<Layout title="Audiophile">
	<Welcome />
	<SiteFooter {...homeFooterContent} />
</Layout>
