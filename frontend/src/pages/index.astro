---
import CategoryBanner from '../components/CategoryBanner.astro';
import { categoryBannerItems } from '../data/category-banner';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Audiophile">
	<main class="home">
		<h1 class="visually-hidden">Audiophile product categories</h1>
		<div class="site-container">
			<CategoryBanner items={categoryBannerItems} imageLoading="eager" />
		</div>
	</main>
</Layout>

<style>
	.home {
		min-block-size: 100vh;
		padding-block: 2rem;
	}

	.visually-hidden {
		position: absolute;
		inline-size: 1px;
		block-size: 1px;
		margin: -1px;
		padding: 0;
		overflow: hidden;
		clip-path: inset(50%);
		border: 0;
		white-space: nowrap;
	}
</style>
