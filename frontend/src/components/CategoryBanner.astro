---
import type { CategoryBannerItem } from '../data/category-banner';

interface Props {
	items: readonly CategoryBannerItem[];
	ariaLabel?: string;
	imageLoading?: 'eager' | 'lazy';
}

const { items, ariaLabel = 'Product categories', imageLoading = 'lazy' } = Astro.props;
const columnCount = Math.min(Math.max(items.length, 1), 3);

const compactArtworkWidths: Readonly<Record<string, string>> = {
	'/assets/shared/desktop/image-category-thumbnail-headphones.png': '8.75rem',
	'/assets/shared/desktop/image-category-thumbnail-speakers.png': '9.375rem',
	'/assets/shared/desktop/image-category-thumbnail-earphones.png': '11.25rem',
};
---

{
	items.length > 0 && (
		<nav class="category-banner" aria-label={ariaLabel}>
			<ul class="category-banner__list" style={`--column-count: ${columnCount}`}>
				{items.map((item) => (
					<li
						class="category-banner__item"
						style={compactArtworkWidths[item.image.src]
							? `--compact-image-width: ${compactArtworkWidths[item.image.src]}`
							: undefined}
					>
						<a
							class="category-banner__link"
							href={item.href}
							aria-current={item.current ? 'page' : undefined}
						>
							<img
								class="category-banner__image"
								src={item.image.src}
								width={item.image.width}
								height={item.image.height}
								alt={item.image.alt}
								loading={imageLoading}
								decoding="async"
							/>
							<span class="category-banner__surface">
								<span class="category-banner__title">{item.name}</span>
								<span class="category-banner__action">
									<span class="category-banner__action-label">{item.actionLabel}</span>
									<img
										class="category-banner__arrow"
										src="/assets/shared/desktop/icon-arrow-right.svg"
										width="8"
										height="12"
										alt=""
									/>
								</span>
							</span>
						</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<style>
	.category-banner {
		container: category-banner / inline-size;
		inline-size: 100%;
		font-family: var(--font-family-sans);
		font-size-adjust: from-font;
	}

	.category-banner__list {
		--item-min-height: 13.5625rem;
		--surface-offset: 3.25rem;
		--surface-min-height: 10.3125rem;
		--image-width: 9.375rem;
		--image-offset-y: 0rem;
		--content-padding-end: 1.125rem;

		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.category-banner__item {
		min-inline-size: 0;
	}

	.category-banner__link {
		position: relative;
		display: flex;
		block-size: 100%;
		min-block-size: var(--item-min-height);
		flex-direction: column;
		padding-block-start: var(--surface-offset);
		border-radius: var(--radius-card);
		color: var(--color-black);
		text-decoration: none;
	}

	.category-banner__link:focus-visible {
		outline: var(--focus-ring-width) solid var(--focus-ring-color-light);
		outline-offset: var(--focus-ring-offset);
	}

	.category-banner__image {
		position: absolute;
		z-index: 2;
		inset-block-start: var(--image-offset-y);
		inset-inline-start: 50%;
		display: block;
		inline-size: var(--compact-image-width, var(--image-width));
		max-inline-size: none;
		block-size: auto;
		transform: translateX(-50%);
		pointer-events: none;
		user-select: none;
	}

	.category-banner__surface {
		position: relative;
		z-index: 1;
		display: flex;
		min-block-size: var(--surface-min-height);
		flex: 1;
		flex-direction: column;
		align-items: center;
		justify-content: flex-end;
		gap: 0.75rem;
		padding: 1rem 1rem var(--content-padding-end);
		border-radius: var(--radius-card);
		background: var(--color-surface-muted);
		text-align: center;
	}

	.category-banner__title {
		font-size: 1.125rem;
		font-weight: var(--font-weight-bold);
		line-height: 1.333333;
		letter-spacing: 0.08125rem;
		text-transform: uppercase;
		overflow-wrap: anywhere;
	}

	.category-banner__action {
		display: inline-flex;
		align-items: center;
		gap: 0.8125rem;
		font-size: 0.8125rem;
		font-weight: var(--font-weight-bold);
		line-height: 1.923077;
		letter-spacing: 0.0625rem;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.category-banner__action-label {
		color: rgb(0 0 0 / 55%);
	}

	.category-banner__arrow {
		display: block;
		inline-size: 0.5rem;
		max-inline-size: none;
		block-size: 0.75rem;
		pointer-events: none;
	}

	.category-banner__link:is(:hover, :focus-visible) .category-banner__action-label {
		color: var(--color-primary-text);
	}

	@container category-banner (min-width: 43rem) {
		.category-banner__list {
			grid-template-columns: repeat(var(--column-count), minmax(0, 1fr));
			gap: 0.625rem;
		}
	}

	@container category-banner (min-width: 58rem) {
		.category-banner__list {
			--item-min-height: 17.75rem;
			--surface-offset: 5rem;
			--surface-min-height: 12.75rem;
			--image-width: 13.75rem;
			--content-padding-end: 1.625rem;

			gap: 1.875rem;
		}

		.category-banner__image {
			inline-size: var(--image-width);
		}
	}
</style>
